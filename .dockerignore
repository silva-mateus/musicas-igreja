.git
.gitignore
**/.DS_Store
**/Thumbs.db

# Backend runtime/state we don't need in image
backend/uploads/
backend/organized/
backend/flask_session/
backend/logs/
backend/**/*.log

# Frontend caches/build outputs
node_modules/
frontend/node_modules/
.next/
frontend/.next/
frontend/out/

# Local env and secrets (db will be included for first deploy separately)
.env
frontend/.env.local
backend/credentials.json
backend/token.json

# Virtual envs
.venv/
backend/.venv/
venv/
backend/venv/