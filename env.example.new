# ===============================
# CONFIGURAÇÕES DO BACKEND (FLASK)
# ===============================

# Chave secreta para Flask (OBRIGATÓRIO EM PRODUÇÃO)
SECRET_KEY=your-super-secret-key-change-in-production

# Ambiente de execução
FLASK_ENV=development

# Configurações de banco de dados
DATABASE_PATH=/app/data/pdf_organizer.db

# Configurações de diretórios
UPLOAD_FOLDER=/app/data/uploads
ORGANIZED_FOLDER=/app/data/organized
LOG_FOLDER=/app/data/logs

# Porta do backend
PORT=5000

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# ===============================
# CONFIGURAÇÕES DO FRONTEND (NEXTJS)
# ===============================

# Ambiente de execução
NODE_ENV=development

# URL da API do backend
NEXT_PUBLIC_API_URL=http://localhost:5000

# Porta do frontend
PORT=3000

# ===============================
# CONFIGURAÇÕES DE PRODUÇÃO
# ===============================

# URL pública da aplicação
APP_URL=https://your-domain.com

# Configurações de container
HOSTNAME=0.0.0.0

# Desabilitar telemetria do NextJS (opcional)
NEXT_TELEMETRY_DISABLED=1

# ===============================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# ===============================

# Debug mode
DEBUG=true

# Hot reload
WATCHPACK_POLLING=true

# ===============================
# CONFIGURAÇÕES OPCIONAIS
# ===============================

# Configurações de email (futuro)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Configurações de storage (futuro)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_BUCKET_NAME=your-bucket

# Configurações de OAuth (futuro)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===============================
# CONFIGURAÇÕES DO DOCKER
# ===============================

# Registry de imagens
REGISTRY=ghcr.io
IMAGE_NAME=your-username/musicas-igreja

# Configurações de build
BUILDKIT_PROGRESS=plain

# ===============================
# EXEMPLO DE USO
# ===============================

# 1. Copie este arquivo para .env:
#    cp env.example.new .env

# 2. Edite as configurações necessárias

# 3. Para desenvolvimento local:
#    docker-compose -f docker-compose.dev.yml up

# 4. Para produção:
#    docker-compose up -d